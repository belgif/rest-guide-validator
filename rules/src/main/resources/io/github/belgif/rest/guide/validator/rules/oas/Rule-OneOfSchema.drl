package io.github.belgif.rest.guide.validator.rules.oas;

import org.eclipse.microprofile.openapi.models.OpenAPI;
import io.github.belgif.rest.guide.validator.core.ApiFunctions;
import io.github.belgif.rest.guide.validator.core.ApiFunctions.ConflictingSchemaValidation;
import io.github.belgif.rest.guide.validator.core.ViolationReport;
global io.github.belgif.rest.guide.validator.core.ViolationReport oas;
import io.github.belgif.rest.guide.validator.core.parser.Parser.ParserResult;
global io.github.belgif.rest.guide.validator.core.parser.Parser.ParserResult parserResult;
import org.eclipse.microprofile.openapi.models.media.Schema;
import org.eclipse.microprofile.openapi.models.media.Schema.SchemaType;
import io.github.belgif.rest.guide.validator.core.model.SchemaDefinition;
import io.github.belgif.rest.guide.validator.core.model.OpenApiDefinition;
import io.github.belgif.rest.guide.validator.core.ViolationLevel;
import java.util.List;
import java.util.Set;
import java.util.HashSet;
import java.lang.Boolean;
import java.util.ArrayList;
import java.util.Collections
import java.util.stream.Collectors
import java.util.Map
import java.util.stream.Stream;

function void violationOneOfSubSchemaEnforcesIllegalConstraints(ViolationReport oas, SchemaDefinition schema, String errorMessage){
    oas.addViolation("[sch-oneof]",
    "use of `oneOf` SHOULD be limited to either: 1. subschemas with only a `required` constraint, without a `type` or other constraint 2. subschemas with an `enum` of the same simple `type` (i.e. no `array` or `object`) 3. subschemas of `type: object`, when a `discriminator` is also defined. Properties may only be defined within the subschemas.", errorMessage, schema, ViolationLevel.RECOMMENDED);
}

function void violationOneOfSubSchemaWithEnumOfDifferentType(ViolationReport oas, SchemaDefinition schema, String conflictingTypes) {
    oas.addViolation("[sch-oneof]",
        "use of `oneOf` SHOULD be limited to either: 1. subschemas with only a `required` constraint, without a `type` or other constraint 2. subschemas with an `enum` of the same simple `type` (i.e. no `array` or `object`) 3. subschemas of `type: object`, when a `discriminator` is also defined. Properties may only be defined within the subschemas.", "Enforces conflicting enum types: <<" + conflictingTypes + ">>", schema, ViolationLevel.RECOMMENDED);
}

function String createErrorMessage(SchemaDefinition oneOfSchemaDef, List<String> props) {
  return "In oneOf subschema <<" + oneOfSchemaDef.getPrintableJsonPointer() + ">>, only `required`constraint expected but encountered << " + props.stream().collect(Collectors.joining(", ")).toString() + " >>";
}

function List validateOneOfSchema(SchemaDefinition schemaWithOneOf, ParserResult parserResult) {
    List<SchemaDefinition> subSchemas = schemaWithOneOf.getModel().getOneOf().stream()
            .map(s -> (SchemaDefinition) parserResult.resolve(s)).toList();
    List<String> errors = new ArrayList<>();

    // case 1. subschemas with only a `required` constraint, without a `type` or other constraint
    List<SchemaDefinition> subSchemasWithoutType = subSchemas.stream()
        .filter(subSchema -> ApiFunctions.findSchemaTypes(subSchema.getModel(), parserResult).allowedTypes() == null)
        .toList();
    if (subSchemasWithoutType.containsAll(subSchemas)) {
        // if no subschema has a type constraint, we assume the intention is to have a oneOf construction with only 'required' constraints
        // swagger-parser puts "x-*" properties under the extensions property
        // Does not include enum because that needs an extra check
        Set<String> allowedProperties = Set.of("required", "description", "example", "title", "extensions", "not");
        List<String> forbiddenPropertiesErrors = subSchemas.stream()
             .map(s -> {
                   List<String> props = ApiFunctions.findNonNullProperties(s.getModel());
                   props.removeAll(allowedProperties);
                   return Map.entry(s, props);
                 })
            .filter(entry -> !entry.getValue().isEmpty())
            .map(entry -> createErrorMessage(entry.getKey(), entry.getValue()))
            .toList();
        return forbiddenPropertiesErrors;
    }

    // case 2. subschemas with an `enum` of the same simple `type` (i.e. no `array` or `object`)
    Set<SchemaType> allowedSimpleTypes = Set.of(SchemaType.INTEGER, SchemaType.STRING, SchemaType.NUMBER, SchemaType.BOOLEAN);
    List<SchemaDefinition> enumAllowedSchemas = subSchemas.stream()
            .filter(subSchema -> subSchema.getModel().getEnumeration() != null
                && (subSchema.getModel().getType() == null ||
                        (subSchema.getModel().getType() != null && allowedSimpleTypes.contains(subSchema.getModel().getType()))
                    )
            )
            .toList();
    if (enumAllowedSchemas.containsAll(subSchemas)) {
      return Collections.EMPTY_LIST;
    }

    // case 3. subschemas of `type: object`, when a `discriminator` is also defined. Properties may only be defined within the subschemas.
    List<SchemaDefinition> discriminatorAllowedSchemas = Collections.EMPTY_LIST;
    if (schemaWithOneOf.getModel().getDiscriminator() != null) {
        discriminatorAllowedSchemas = subSchemas.stream()
            .filter(subSchema -> subSchema.getModel().getType() != null
               && ApiFunctions.findSchemaTypes(subSchema.getModel(), parserResult).allowedTypes().contains(SchemaType.OBJECT))
            .toList();
        if (discriminatorAllowedSchemas.containsAll(subSchemas)) {
          List<String> parentProps = ApiFunctions.findNonNullProperties(schemaWithOneOf.getModel());
          if (parentProps.contains("properties")) {
              errors.add("oneOf schemas that declare a discriminator should only declare properties in the oneOf subschemas");
              return errors;
          } else {
            return Collections.EMPTY_LIST;
          }
        }
     }

     errors.add("All subschemas should comply with one of the allowed uses for a oneOf schema.");
     return errors;
}

function String getConflictingTypesInEnum(SchemaDefinition schemaDefinition, ParserResult parserResult) {
  if (schemaDefinition.getModel().getOneOf().stream().map(s -> parserResult.resolve(s).getModel()).allMatch(s -> s.getEnumeration() == null || s.getEnumeration().isEmpty())) {
    return null;
  }
  Set<SchemaType> types = ApiFunctions.findSchemaTypes(schemaDefinition.getModel(), parserResult).allowedTypes();
  return types.isEmpty() || types.size() == 1 ? null : types.stream().map(SchemaType::toString).collect(Collectors.joining(", ")).toString();
}

rule "OneOf Should Not Enforce Other Properties Than Required or Enum"
    when
        $schemaDefinition: SchemaDefinition(model.getOneOf() != null)
        $errorMessage: String() from validateOneOfSchema($schemaDefinition, parserResult)
    then
        violationOneOfSubSchemaEnforcesIllegalConstraints(oas, $schemaDefinition, $errorMessage);
end

rule "OneOf with enum constraint should be of the same simple type"
  when
      $schemaDefinition: SchemaDefinition(model.getOneOf() != null)
      $conflictingTypes: String() from getConflictingTypesInEnum($schemaDefinition, parserResult)
  then
      violationOneOfSubSchemaWithEnumOfDifferentType(oas, $schemaDefinition, $conflictingTypes);
end