    when
        $api: OpenAPI()
        $operationId: String() from ApiPathFunctions.operationIdDontHaveConsume(jsonString, HttpMethod.PUT)
    then
        violationConsume(oas, HttpMethod.PUT.name(), $operationId);
end
rule "Rule-defaultMediaType-putDontHaveCorrectConsumes"
    when
        $api: OpenAPI()
        $operationData: OperationData() from ApiPathFunctions.operationDataDontHaveConsume(jsonString, HttpMethod.PUT, ApiPathFunctions.CONSUMES_MEDIATYPE)
    then
        violationConsume(oas, HttpMethod.PUT.name(), $operationData.getOperationId());
end

rule "Rule-defaultMediaType-patchDontHaveConsumes"
