        $operationData: OperationData() from ApiPathFunctions.operationDataDontHaveConsume(jsonString, HttpMethod.POST, ApiPathFunctions.CONSUMES_MEDIATYPE)
    then
        violationConsume(oas, HttpMethod.POST.name(), $operationData.getOperationId());
