package be.belgium.gcloud.rest.styleguide.validation.core.rules.oas;

import org.eclipse.microprofile.openapi.models.PathItem.HttpMethod;
import org.eclipse.microprofile.openapi.models.OpenAPI;
import be.belgium.gcloud.rest.styleguide.validation.core.ApiFunctions
import be.belgium.gcloud.rest.styleguide.validation.core.OpenApiViolationAggregator;
global be.belgium.gcloud.rest.styleguide.validation.core.OpenApiViolationAggregator oas;

function void violationGet(OpenApiViolationAggregator oas, String operationId, String code){
    oas.addViolation("[stat-codes]", "GET operation should not have a status code: "+code,
                     oas.getLineNumber(oas.getLineNumber(operationId), code));
}


rule "Get Status Code 201 v3"
	when
		$api: OpenAPI()
		$operationId: String() from ApiFunctions.getOperationId($api, HttpMethod.GET, "201")
	then
        violationGet(oas, $operationId, "201");
end
rule "Get Status Code 202 v3"
	when
		$api: OpenAPI()
		$operationId: String() from ApiFunctions.getOperationId($api, HttpMethod.GET, "202")
	then
        violationGet(oas, $operationId, "202");
end
rule "Get Status Code 204 v3"
	when
		$api: OpenAPI()
		$operationId: String() from ApiFunctions.getOperationId($api, HttpMethod.GET, "204")
	then
        violationGet(oas, $operationId, "204");
end
rule "Get Status Code 409 v3"
	when
		$api: OpenAPI()
		$operationId: String() from ApiFunctions.getOperationId($api, HttpMethod.GET, "409")
	then
        violationGet(oas, $operationId, "409");
end
rule "Get Status Code 412 v3"
	when
		$api: OpenAPI()
		$operationId: String() from ApiFunctions.getOperationId($api, HttpMethod.GET, "412")
	then
        violationGet(oas, $operationId, "412");
end
rule "Get Status Code 413 v3"
	when
		$api: OpenAPI()
		$operationId: String() from ApiFunctions.getOperationId($api, HttpMethod.GET, "413")
	then
        violationGet(oas, $operationId, "413");
end